<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Rahul Partel — Designer & Creative</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --v0: #ffffff;
    --v1: #f5f0ff;
    --v2: #ede4ff;
    --v3: #ddd0ff;
    --v4: #c9b4fd;
    --v5: #a98ef5;
    --v6: #7c5ce8;
    --v7: #5a3dba;
    --ink: #1e1530;
    --ink-soft: #4a3a6e;
    --ink-muted: #9080b8;
    --surface: #faf8ff;
    --card-bg: rgba(255,255,255,0.72);
    --radius-sm: 12px;
    --radius-md: 20px;
    --radius-lg: 32px;
    --radius-pill: 999px;
    --font-display: 'DM Serif Display', serif;
    --font-body: 'DM Sans', sans-serif;
    --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --ease-smooth: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--surface);
    color: var(--ink);
    overflow-x: hidden;
    line-height: 1.6;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 9999; opacity: 0.5;
  }

  .bg-blobs { position: fixed; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
  .blob { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.5; animation: drift 20s ease-in-out infinite; }
  .blob-1 { width: 650px; height: 650px; background: var(--v3); top: -120px; left: -180px; animation-delay: 0s; }
  .blob-2 { width: 520px; height: 520px; background: var(--v2); top: 25%; right: -140px; animation-delay: -7s; }
  .blob-3 { width: 480px; height: 480px; background: var(--v4); bottom: 8%; left: 15%; animation-delay: -13s; opacity: 0.35; }
  .blob-4 { width: 380px; height: 380px; background: var(--v2); bottom: -90px; right: 8%; animation-delay: -5s; }
  @keyframes drift {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(28px,-18px) scale(1.04); }
    66% { transform: translate(-18px,28px) scale(0.97); }
  }

  nav {
    position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
    z-index: 100;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(200,180,255,0.4);
    border-radius: var(--radius-pill);
    padding: 10px 28px;
    display: flex; align-items: center; gap: 32px;
    box-shadow: 0 4px 28px rgba(122,92,232,0.1);
    animation: slideDown 0.7s var(--ease-spring) both;
  }
  @keyframes slideDown {
    from { opacity:0; transform: translateX(-50%) translateY(-20px); }
    to   { opacity:1; transform: translateX(-50%) translateY(0); }
  }
  .nav-logo { font-family: var(--font-display); font-size: 17px; color: var(--ink); letter-spacing: -0.3px; }
  .nav-links { display: flex; gap: 24px; }
  .nav-links a { font-size: 14px; font-weight: 400; color: var(--ink-soft); text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--v6); }
  .nav-cta {
    background: linear-gradient(135deg, var(--v6), var(--v5));
    color: white !important; padding: 7px 18px; border-radius: var(--radius-pill);
    font-size: 13px !important; font-weight: 500 !important;
    transition: transform 0.2s var(--ease-spring), box-shadow 0.2s !important;
  }
  .nav-cta:hover { transform: scale(1.05) !important; box-shadow: 0 4px 18px rgba(122,92,232,0.4) !important; }

  main { position: relative; z-index: 1; }
  .section { max-width: 1080px; margin: 0 auto; padding: 0 32px; }

  .hero { min-height: 100vh; display: flex; align-items: center; padding-top: 100px; padding-bottom: 80px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--v2); color: var(--v6);
    font-size: 12px; font-weight: 500;
    padding: 6px 14px; border-radius: var(--radius-pill); margin-bottom: 24px;
    animation: fadeUp 0.8s var(--ease-smooth) 0.3s both;
  }
  .hero-tag::before { content: '●'; font-size: 8px; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(42px, 5vw, 66px);
    line-height: 1.08; letter-spacing: -1.5px; color: var(--ink); margin-bottom: 22px;
    animation: fadeUp 0.8s var(--ease-smooth) 0.45s both;
  }
  .hero-title em { font-style: italic; background: linear-gradient(135deg, var(--v6), var(--v5)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-subtitle { font-size: 17px; color: var(--ink-soft); line-height: 1.75; max-width: 420px; margin-bottom: 40px; animation: fadeUp 0.8s var(--ease-smooth) 0.6s both; }
  .hero-actions { display: flex; gap: 14px; animation: fadeUp 0.8s var(--ease-smooth) 0.75s both; }
  .btn-primary {
    background: linear-gradient(135deg, var(--v7), var(--v6));
    color: white; padding: 14px 28px; border-radius: var(--radius-pill);
    font-size: 15px; font-weight: 500; text-decoration: none;
    transition: transform 0.25s var(--ease-spring), box-shadow 0.25s; display: inline-block;
  }
  .btn-primary:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 10px 32px rgba(122,92,232,0.35); }
  .btn-ghost {
    background: transparent; color: var(--ink-soft);
    padding: 14px 28px; border-radius: var(--radius-pill);
    font-size: 15px; font-weight: 400; text-decoration: none;
    border: 1.5px solid rgba(170,140,255,0.35);
    transition: all 0.2s; display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--v5); color: var(--v6); background: var(--v2); }

  .hero-visual { display: flex; justify-content: center; align-items: center; animation: floatIn 1s var(--ease-spring) 0.5s both; }
  @keyframes floatIn { from{opacity:0;transform:translateY(30px) scale(0.95)} to{opacity:1;transform:translateY(0) scale(1)} }
  .hero-avatar-wrap { position: relative; width: 340px; height: 380px; }
  .avatar-blob {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--v3), var(--v4), var(--v5));
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    animation: morphBlob 8s ease-in-out infinite;
  }
  @keyframes morphBlob {
    0%,100% { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
    33%     { border-radius: 45% 55% 40% 60% / 60% 40% 55% 45%; }
    66%     { border-radius: 55% 45% 60% 40% / 40% 55% 45% 60%; }
  }
  .avatar-img {
    position: absolute; inset: 16px;
    border-radius: 50% 45% 55% 50% / 52% 55% 45% 48%;
    background: var(--v2); overflow: hidden;
    display: flex; align-items: flex-end; justify-content: center;
  }
  .avatar-placeholder {
    width: 80%; height: 88%;
    background: linear-gradient(180deg, var(--v3) 0%, var(--v5) 100%);
    border-radius: 50% 50% 0 0; position: relative;
  }
  .avatar-placeholder::before {
    content: ''; position: absolute; top: 18%; left: 50%;
    transform: translateX(-50%); width: 44%; height: 44%;
    background: white; border-radius: 50%; opacity: 0.75;
  }
  .floating-chip {
    position: absolute;
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(200,180,255,0.5);
    border-radius: var(--radius-sm);
    padding: 10px 16px; font-size: 13px; font-weight: 500; color: var(--ink);
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(122,92,232,0.12);
    white-space: nowrap;
  }
  .chip-1 { top: 20px; right: -20px; animation: cf1 4s ease-in-out infinite; }
  .chip-2 { bottom: 40px; left: -30px; animation: cf2 5s ease-in-out infinite; }
  .chip-3 { bottom: 120px; right: -10px; animation: cf1 6s ease-in-out infinite 1s; }
  @keyframes cf1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  @keyframes cf2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }
  .chip-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }
  .dot-v { background: var(--v5); }
  .dot-vd { background: var(--v6); }
  .dot-vl { background: var(--v4); }

  .section-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 500; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--ink-muted); margin-bottom: 16px;
  }
  .section-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--v4); }

  .work { padding: 100px 0; }
  .work-header { margin-bottom: 56px; }
  .section-title { font-family: var(--font-display); font-size: clamp(36px,4vw,52px); letter-spacing: -1.2px; line-height: 1.1; color: var(--ink); }
  .section-title em { font-style: italic; background: linear-gradient(135deg, var(--v6), var(--v5)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .project-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .project-card {
    background: var(--card-bg);
    border: 1px solid rgba(200,180,255,0.35);
    border-radius: var(--radius-md); overflow: hidden;
    transition: transform 0.35s var(--ease-spring), box-shadow 0.35s;
    cursor: pointer; backdrop-filter: blur(14px);
  }
  .project-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(122,92,232,0.18); }
  .project-card.large { grid-column: span 2; }
  .project-thumb { overflow: hidden; position: relative; }
  .project-thumb svg { width: 100%; display: block; }
  .project-info { padding: 24px; }
  .project-tags { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
  .tag { font-size: 11px; font-weight: 500; letter-spacing: 0.5px; padding: 4px 12px; border-radius: var(--radius-pill); }
  .tag-v1 { background: var(--v2); color: var(--v7); }
  .tag-v2 { background: var(--v3); color: var(--v7); }
  .tag-v3 { background: #f0e8ff; color: var(--v6); }
  .project-name { font-family: var(--font-display); font-size: 22px; letter-spacing: -0.5px; color: var(--ink); margin-bottom: 8px; }
  .project-desc { font-size: 14px; color: var(--ink-soft); line-height: 1.65; }

  .about { padding: 100px 0; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .about-text p { font-size: 16px; color: var(--ink-soft); line-height: 1.8; margin-bottom: 20px; }
  .about-text p:first-child { font-family: var(--font-display); font-size: 26px; line-height: 1.4; color: var(--ink); letter-spacing: -0.5px; margin-bottom: 24px; }
  .skills-list { display: flex; flex-direction: column; gap: 16px; }
  .skill-header { display: flex; justify-content: space-between; margin-bottom: 8px; }
  .skill-name { font-size: 14px; font-weight: 500; color: var(--ink); }
  .skill-pct { font-size: 13px; color: var(--ink-muted); }
  .skill-bar { height: 6px; background: var(--v2); border-radius: var(--radius-pill); overflow: hidden; }
  .skill-fill {
    height: 100%; border-radius: var(--radius-pill);
    transform-origin: left; transform: scaleX(0);
    transition: transform 1s var(--ease-smooth);
    background: linear-gradient(90deg, var(--v4), var(--v6));
  }

  .testimonials { padding: 100px 0; }
  .testimonials-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .testi-card {
    background: var(--card-bg); border: 1px solid rgba(200,180,255,0.35);
    border-radius: var(--radius-md); padding: 28px; backdrop-filter: blur(14px);
    transition: transform 0.3s var(--ease-spring);
  }
  .testi-card:hover { transform: translateY(-4px); }
  .testi-stars { color: var(--v5); font-size: 14px; margin-bottom: 16px; letter-spacing: 2px; }
  .testi-text { font-size: 15px; color: var(--ink-soft); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
  .testi-author { display: flex; align-items: center; gap: 12px; }
  .author-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 500; color: white; flex-shrink: 0;
    background: linear-gradient(135deg, var(--v5), var(--v6));
  }
  .av-b { background: linear-gradient(135deg, var(--v4), var(--v6)); }
  .av-c { background: linear-gradient(135deg, var(--v5), var(--v7)); }
  .author-name { font-size: 14px; font-weight: 500; color: var(--ink); }
  .author-role { font-size: 12px; color: var(--ink-muted); }

  .contact { padding: 100px 0; }
  .contact-card {
    background: var(--card-bg); border: 1px solid rgba(200,180,255,0.35);
    border-radius: var(--radius-lg); padding: 72px; text-align: center;
    backdrop-filter: blur(20px); position: relative; overflow: hidden;
  }
  .contact-card::before {
    content: ''; position: absolute; top: -40%; left: 50%; transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(196,168,253,0.25) 0%, transparent 70%);
    pointer-events: none;
  }
  .contact-title { font-family: var(--font-display); font-size: 48px; letter-spacing: -1.5px; color: var(--ink); margin-bottom: 16px; }
  .contact-title em { font-style: italic; background: linear-gradient(135deg, var(--v6), var(--v5)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .contact-sub { font-size: 17px; color: var(--ink-soft); max-width: 420px; margin: 0 auto 40px; }
  .contact-form { max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-input {
    width: 100%; padding: 14px 18px;
    border: 1.5px solid rgba(180,150,255,0.25);
    border-radius: var(--radius-sm);
    background: rgba(255,255,255,0.8);
    font-family: var(--font-body); font-size: 15px; color: var(--ink);
    outline: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-input:focus { border-color: var(--v5); box-shadow: 0 0 0 4px rgba(169,142,245,0.15); }
  .form-input::placeholder { color: var(--ink-muted); }
  .form-textarea { min-height: 120px; resize: vertical; }
  .form-submit {
    background: linear-gradient(135deg, var(--v7), var(--v6));
    color: white; border: none; padding: 16px 32px; border-radius: var(--radius-pill);
    font-family: var(--font-body); font-size: 15px; font-weight: 500; cursor: pointer;
    transition: transform 0.25s var(--ease-spring), box-shadow 0.25s; margin-top: 4px;
  }
  .form-submit:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 10px 32px rgba(122,92,232,0.35); }

  footer { padding: 40px 32px; font-size: 14px; color: var(--ink-muted); border-top: 1px solid rgba(180,150,255,0.15); }
  .footer-inner { max-width: 1080px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
  .footer-links { display: flex; gap: 24px; }
  .footer-links a { color: var(--ink-muted); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--v6); }

  @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
  .reveal { opacity:0; transform:translateY(30px); transition: opacity 0.7s var(--ease-smooth), transform 0.7s var(--ease-smooth); }
  .reveal.visible { opacity:1; transform:translateY(0); }

  .scroll-line {
    position: fixed; top:0; left:0; height:3px;
    background: linear-gradient(90deg, var(--v3), var(--v5), var(--v6));
    z-index: 200; width:0%; transition: width 0.1s linear; border-radius: 0 2px 2px 0;
  }

  @media (max-width: 768px) {
    .hero-inner, .about-grid { grid-template-columns: 1fr; }
    .project-grid { grid-template-columns: 1fr; }
    .project-card.large { grid-column: span 1; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .contact-card { padding: 40px 24px; }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; gap: 16px; }
    nav { width: calc(100% - 32px); padding: 10px 20px; }
    .nav-links { display: none; }
  }
</style>
</head>
<body>

<div class="scroll-line" id="scrollLine"></div>
<div class="bg-blobs">
  <div class="blob blob-1"></div><div class="blob blob-2"></div>
  <div class="blob blob-3"></div><div class="blob blob-4"></div>
</div>

<nav>
  <span class="nav-logo">Rahul Partel.</span>
  <div class="nav-links">
    <a href="#work">Work</a>
    <a href="#about">About</a>
    <a href="#testimonials">Praise</a>
    <a href="#contact" class="nav-cta">Let's Talk →</a>
  </div>
</nav>

<main>

  <!-- HERO -->
  <section class="hero section">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-tag">Available for projects</div>
        <h1 class="hero-title">Product Designer &<br><em>Creative Mind</em><br>based in Mumbai.</h1>
        <p class="hero-subtitle">I craft digital experiences that blend beauty with purpose — turning complex ideas into interfaces people genuinely love to use.</p>
        <div class="hero-actions">
          <a href="#work" class="btn-primary">See my work</a>
          <a href="#contact" class="btn-ghost">Get in touch</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-avatar-wrap">
          <div class="avatar-blob"></div>
          <div class="avatar-img">
            <!-- ✏️ Replace with: <img src="rahul.jpg" style="width:100%;height:100%;object-fit:cover;"> -->
            <div class="avatar-placeholder"></div>
          </div>
          <div class="floating-chip chip-1"><span class="chip-dot dot-v"></span> 18+ Projects</div>
          <div class="floating-chip chip-2"><span class="chip-dot dot-vd"></span> Product Design</div>
          <div class="floating-chip chip-3"><span class="chip-dot dot-vl"></span> ✦ Awwwards 2024</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section class="work section" id="work">
    <div class="work-header reveal">
      <div class="section-label">Selected work</div>
      <h2 class="section-title">Projects I'm<br><em>proud</em> of</h2>
    </div>
    <div class="project-grid">

      <!-- PROJECT 1 — Lumis AI (wide featured) -->
      <div class="project-card large reveal">
        <div class="project-thumb">
          <svg viewBox="0 0 900 300" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" style="height:300px">
            <defs>
              <linearGradient id="bg1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#f0e8ff"/><stop offset="100%" stop-color="#ddd0ff"/>
              </linearGradient>
              <linearGradient id="btn1" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#7c5ce8"/><stop offset="100%" stop-color="#a98ef5"/>
              </linearGradient>
            </defs>
            <rect width="900" height="300" fill="url(#bg1)"/>
            <!-- Nav -->
            <rect x="0" y="0" width="900" height="44" fill="rgba(255,255,255,0.72)"/>
            <text x="32" y="27" font-family="Georgia,serif" font-size="15" font-weight="700" fill="#1e1530">Lumis</text>
            <text x="200" y="27" font-family="sans-serif" font-size="11" fill="#4a3a6e">Features</text>
            <text x="270" y="27" font-family="sans-serif" font-size="11" fill="#4a3a6e">Pricing</text>
            <text x="336" y="27" font-family="sans-serif" font-size="11" fill="#4a3a6e">Blog</text>
            <rect x="762" y="11" width="88" height="22" rx="11" fill="url(#btn1)"/>
            <text x="806" y="26" font-family="sans-serif" font-size="10" fill="white" text-anchor="middle">Get started</text>
            <!-- Hero copy -->
            <text x="450" y="100" font-family="Georgia,serif" font-size="34" fill="#1e1530" text-anchor="middle" font-weight="700">Write smarter,</text>
            <text x="450" y="140" font-family="Georgia,serif" font-size="34" fill="#7c5ce8" text-anchor="middle" font-style="italic">not harder.</text>
            <text x="450" y="166" font-family="sans-serif" font-size="13" fill="#4a3a6e" text-anchor="middle">AI-powered writing assistant for teams that move fast.</text>
            <!-- CTAs -->
            <rect x="292" y="184" width="180" height="36" rx="18" fill="url(#btn1)"/>
            <text x="382" y="207" font-family="sans-serif" font-size="12" fill="white" text-anchor="middle">Start for free →</text>
            <rect x="486" y="184" width="124" height="36" rx="18" fill="rgba(255,255,255,0.65)" stroke="#c9b4fd" stroke-width="1"/>
            <text x="548" y="207" font-family="sans-serif" font-size="12" fill="#7c5ce8" text-anchor="middle">See demo</text>
